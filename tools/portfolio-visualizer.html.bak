<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Portfolio Drawdown Visualizer</title>
  <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.1/dist/chart.umd.min.js"></script>
  <link href="https://fonts.googleapis.com/css2?family=DM+Sans:opsz,wght@9..40,300;9..40,400;9..40,500;9..40,600&family=Space+Mono:wght@400;700&display=swap" rel="stylesheet">
  <style>
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }
    
    body {
      min-height: 100vh;
      background: #0a0a0b;
      color: #e8e8e8;
      font-family: 'DM Sans', sans-serif;
      padding: 0 40px 40px;
      background-image: 
        radial-gradient(ellipse at 20% 0%, rgba(99, 102, 241, 0.08) 0%, transparent 50%),
        radial-gradient(ellipse at 80% 100%, rgba(16, 185, 129, 0.06) 0%, transparent 50%);
    }
    
    .header {
      max-width: 1400px;
      margin: 0 auto 48px;
      animation: fadeIn 0.6s ease-out;
    }
    
    @keyframes fadeIn {
      from { opacity: 0; transform: translateY(-10px); }
      to { opacity: 1; transform: translateY(0); }
    }
    
    .header h1 {
      font-family: 'Space Mono', monospace;
      font-size: 32px;
      font-weight: 700;
      letter-spacing: -1px;
      margin-bottom: 8px;
      background: linear-gradient(135deg, #fff 0%, #a5a5a5 100%);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
    }
    
    .header p {
      color: #666;
      font-size: 15px;
      letter-spacing: 0.5px;
    }
    
    .tab-nav {
      display: flex;
      gap: 8px;
      margin-top: 24px;
      align-items: center;
    }
    
    .tab-btn {
      padding: 12px 24px;
      background: #1a1a1c;
      border: 1px solid #333;
      color: #666;
      font-family: 'Space Mono', monospace;
      font-size: 13px;
      font-weight: 700;
      cursor: pointer;
      border-radius: 8px;
      transition: all 0.2s ease;
    }
    
    .tab-btn:hover {
      border-color: #444;
      color: #888;
    }
    
    .tab-btn.active {
      background: linear-gradient(135deg, #6366f1 0%, #4f46e5 100%);
      border-color: transparent;
      color: #fff;
      box-shadow: 0 2px 12px rgba(99, 102, 241, 0.3);
    }
    
    .default-btn {
      padding: 12px 24px;
      background: transparent;
      border: 1px dashed #444;
      color: #666;
      font-family: 'Space Mono', monospace;
      font-size: 13px;
      font-weight: 700;
      cursor: pointer;
      border-radius: 8px;
      transition: all 0.2s ease;
      margin-left: auto;
    }
    
    .default-btn:hover {
      border-color: #10b981;
      color: #10b981;
      background: rgba(16, 185, 129, 0.1);
    }
    
    .tab-content {
      display: none !important;
    }
    
    .tab-content.active {
      display: grid !important;
    }
    
    .main-grid {
      max-width: 1400px;
      margin: 0 auto;
      display: grid;
      grid-template-columns: 340px 1fr;
      gap: 32px;
      animation: fadeIn 0.8s ease-out 0.1s both;
    }
    
    .controls-panel {
      background: linear-gradient(145deg, #141416 0%, #0f0f10 100%);
      border: 1px solid #222;
      border-radius: 20px;
      padding: 28px;
      height: fit-content;
      position: sticky;
      top: 40px;
    }
    
    .controls-title {
      font-family: 'Space Mono', monospace;
      font-size: 11px;
      text-transform: uppercase;
      letter-spacing: 2px;
      color: #555;
      margin-bottom: 24px;
      padding-bottom: 16px;
      border-bottom: 1px solid #222;
    }
    
    .input-group {
      margin-bottom: 28px;
    }
    
    .input-header {
      display: flex;
      justify-content: space-between;
      align-items: baseline;
      margin-bottom: 12px;
    }
    
    .input-header label {
      font-size: 13px;
      color: #888;
      font-weight: 500;
    }
    
    .input-value {
      font-family: 'Space Mono', monospace;
      font-size: 16px;
      font-weight: 700;
      color: #fff;
    }
    
    input[type="range"] {
      width: 100%;
      height: 6px;
      -webkit-appearance: none;
      background: #222;
      border-radius: 3px;
      outline: none;
      cursor: pointer;
    }
    
    input[type="range"]::-webkit-slider-thumb {
      -webkit-appearance: none;
      width: 18px;
      height: 18px;
      background: linear-gradient(135deg, #6366f1 0%, #4f46e5 100%);
      border-radius: 50%;
      cursor: pointer;
      box-shadow: 0 2px 8px rgba(99, 102, 241, 0.4);
      transition: transform 0.15s ease, box-shadow 0.15s ease;
    }
    
    input[type="range"]::-webkit-slider-thumb:hover {
      transform: scale(1.1);
      box-shadow: 0 4px 12px rgba(99, 102, 241, 0.5);
    }
    
    input[type="range"]::-moz-range-thumb {
      width: 18px;
      height: 18px;
      background: linear-gradient(135deg, #6366f1 0%, #4f46e5 100%);
      border-radius: 50%;
      cursor: pointer;
      border: none;
      box-shadow: 0 2px 8px rgba(99, 102, 241, 0.4);
    }
    
    .input-range {
      display: flex;
      justify-content: space-between;
      margin-top: 8px;
      font-size: 10px;
      color: #444;
      font-family: 'Space Mono', monospace;
    }
    
    .toggle-group {
      display: flex;
      background: #1a1a1c;
      border-radius: 10px;
      padding: 4px;
      margin-bottom: 24px;
    }
    
    .toggle-btn {
      flex: 1;
      padding: 10px 12px;
      background: transparent;
      border: none;
      color: #666;
      font-size: 12px;
      font-family: 'DM Sans', sans-serif;
      font-weight: 500;
      cursor: pointer;
      border-radius: 8px;
      transition: all 0.2s ease;
    }
    
    .toggle-btn.active {
      background: linear-gradient(135deg, #6366f1 0%, #4f46e5 100%);
      color: #fff;
      box-shadow: 0 2px 8px rgba(99, 102, 241, 0.3);
    }
    
    .chart-panel {
      background: linear-gradient(145deg, #141416 0%, #0f0f10 100%);
      border: 1px solid #222;
      border-radius: 20px;
      padding: 28px;
    }
    
    .metrics-grid {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 16px;
      margin-bottom: 32px;
    }
    
    .metric-card {
      background: #1a1a1c;
      border: 1px solid #252528;
      border-radius: 12px;
      padding: 18px;
      display: flex;
      flex-direction: column;
      transition: transform 0.2s ease, border-color 0.2s ease;
    }
    
    .metric-card:hover {
      transform: translateY(-2px);
      border-color: #333;
    }
    
    .metric-card.highlight {
      background: linear-gradient(145deg, rgba(99, 102, 241, 0.1) 0%, rgba(99, 102, 241, 0.05) 100%);
      border-color: rgba(99, 102, 241, 0.3);
    }
    
    .metric-label {
      font-size: 11px;
      text-transform: uppercase;
      letter-spacing: 1px;
      color: #555;
      margin-bottom: 8px;
      font-weight: 500;
    }
    
    .metric-value {
      font-family: 'Space Mono', monospace;
      font-size: 20px;
      font-weight: 700;
      color: #fff;
    }
    
    .metric-card.highlight .metric-value {
      background: linear-gradient(135deg, #6366f1 0%, #818cf8 100%);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
    }
    
    .metric-subtext {
      font-size: 11px;
      color: #444;
      margin-top: 6px;
    }
    
    .chart-container {
      height: 420px;
      margin-top: 8px;
      position: relative;
    }
    
    .chart-legend {
      display: flex;
      justify-content: center;
      gap: 32px;
      flex-wrap: wrap;
      margin-top: 20px;
    }
    
    .legend-item {
      display: flex;
      align-items: center;
      gap: 8px;
      font-size: 12px;
      color: #666;
    }
    
    .legend-dot {
      width: 10px;
      height: 10px;
      border-radius: 50%;
    }
    
    .legend-dot.growth {
      background: linear-gradient(135deg, #10b981 0%, #059669 100%);
    }
    
    .legend-dot.drawdown {
      background: linear-gradient(135deg, #6366f1 0%, #4f46e5 100%);
    }
    
    .warning-badge {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      background: rgba(239, 68, 68, 0.1);
      border: 1px solid rgba(239, 68, 68, 0.2);
      color: #ef4444;
      font-size: 11px;
      padding: 6px 12px;
      border-radius: 20px;
      margin-top: 4px;
    }
    
    .success-badge {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      background: rgba(16, 185, 129, 0.1);
      border: 1px solid rgba(16, 185, 129, 0.2);
      color: #10b981;
      font-size: 11px;
      padding: 6px 12px;
      border-radius: 20px;
      margin-top: 4px;
    }
    
    .strategy-note {
      background: rgba(245, 158, 11, 0.1);
      border: 1px solid rgba(245, 158, 11, 0.2);
      border-radius: 10px;
      padding: 14px;
      font-size: 12px;
      color: #f59e0b;
      margin-bottom: 24px;
      line-height: 1.5;
    }
    
    .calculated-rate {
      background: linear-gradient(145deg, rgba(245, 158, 11, 0.15) 0%, rgba(245, 158, 11, 0.05) 100%);
      border: 1px solid rgba(245, 158, 11, 0.3);
      border-radius: 12px;
      padding: 20px;
      text-align: center;
      margin-top: 8px;
    }
    
    .calculated-label {
      display: block;
      font-size: 11px;
      text-transform: uppercase;
      letter-spacing: 1px;
      color: #888;
      margin-bottom: 8px;
    }
    
    .calculated-value {
      display: block;
      font-family: 'Space Mono', monospace;
      font-size: 32px;
      font-weight: 700;
      background: linear-gradient(135deg, #f59e0b 0%, #f97316 100%);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
    }
    
    .calculated-sublabel {
      display: block;
      font-size: 11px;
      color: #555;
      margin-top: 4px;
    }
    
    .depleted-badge {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      background: rgba(245, 158, 11, 0.1);
      border: 1px solid rgba(245, 158, 11, 0.2);
      color: #f59e0b;
      font-size: 11px;
      padding: 6px 12px;
      border-radius: 20px;
      margin-top: 4px;
    }
    
    @media (max-width: 1200px) {
      .main-grid {
        grid-template-columns: 1fr;
      }
      
      .controls-panel {
        position: static;
      }
      
      .metrics-grid {
        grid-template-columns: repeat(2, 1fr);
      }
    }
    
    @media (max-width: 600px) {
      body {
        padding: 0 16px 24px;
      }

      nav {
        padding: 12px 0 12px !important;
        height: auto !important;
      }
      
      .header h1 {
        font-size: 22px;
      }

      .header p {
        font-size: 13px;
      }

      .tab-nav {
        flex-wrap: wrap;
      }

      .tab-btn, .default-btn {
        padding: 10px 16px;
        font-size: 12px;
      }

      .default-btn {
        margin-left: 0;
      }

      .controls-panel {
        padding: 20px;
        border-radius: 14px;
      }

      .chart-panel {
        padding: 16px;
        border-radius: 14px;
      }
      
      .metrics-grid {
        grid-template-columns: 1fr 1fr;
        gap: 10px;
      }

      .metric-card {
        padding: 12px;
      }

      .metric-value {
        font-size: 16px;
      }
      
      .chart-container {
        height: 280px;
      }
    }
  </style>
</head>
<body>
  <nav style="max-width:1400px;margin:0 auto;padding:20px 0 16px;display:flex;align-items:center;height:56px;"><a href="/" style="color:#555;text-decoration:none;font-size:14px;font-family:-apple-system,BlinkMacSystemFont,sans-serif;display:inline-flex;align-items:center;gap:6px;transition:color 0.2s;" onmouseover="this.style.color='#fff'" onmouseout="this.style.color='#555'">← Tamation</a></nav>
  <header class="header">
    <h1>Portfolio Drawdown Visualizer</h1>
    <p>Model your retirement portfolio growth and withdrawal strategy</p>
    
    <div class="tab-nav">
      <button class="tab-btn active" id="tabConservative">Conservative</button>
      <button class="tab-btn" id="tabAggressive">Aggressive</button>
      <button class="default-btn" id="btnDefault">Default</button>
    </div>
  </header>
  
  <!-- Conservative Tab -->
  <div class="main-grid tab-content active" id="conservativeTab">
    <div class="controls-panel">
      <div class="controls-title">Parameters</div>
      
      <div class="input-group">
        <div class="input-header">
          <label>Starting Balance</label>
          <span class="input-value" id="startingBalanceValue">$800,000</span>
        </div>
        <input type="range" id="startingBalance" min="100000" max="5000000" step="50000" value="800000">
        <div class="input-range">
          <span>$100,000</span>
          <span>$5,000,000</span>
        </div>
      </div>
      
      <div class="input-group">
        <div class="input-header">
          <label>Current Age</label>
          <span class="input-value" id="currentAgeValue">43 yrs</span>
        </div>
        <input type="range" id="currentAge" min="20" max="70" step="1" value="43">
        <div class="input-range">
          <span>20 yrs</span>
          <span>70 yrs</span>
        </div>
      </div>
      
      <div class="input-group">
        <div class="input-header">
          <label>Age to Start Drawdown</label>
          <span class="input-value" id="drawdownAgeValue">65 yrs</span>
        </div>
        <input type="range" id="drawdownAge" min="21" max="80" step="1" value="65">
        <div class="input-range">
          <span>21 yrs</span>
          <span>80 yrs</span>
        </div>
      </div>
      
      <div class="input-group">
        <div class="input-header">
          <label>Annual Return Rate</label>
          <span class="input-value" id="annualReturnValue">7%</span>
        </div>
        <input type="range" id="annualReturn" min="0" max="15" step="0.5" value="7">
        <div class="input-range">
          <span>0%</span>
          <span>15%</span>
        </div>
      </div>
      
      <div class="controls-title" style="margin-top: 8px;">Withdrawal Strategy</div>
      
      <div class="toggle-group">
        <button class="toggle-btn active" id="togglePercent">% of Balance</button>
        <button class="toggle-btn" id="toggleFixed">Fixed Monthly</button>
      </div>
      
      <div class="input-group" id="percentGroup">
        <div class="input-header">
          <label>Annual Withdrawal Rate</label>
          <span class="input-value" id="drawdownPercentValue">4%</span>
        </div>
        <input type="range" id="drawdownPercent" min="0" max="10" step="0.5" value="4">
        <div class="input-range">
          <span>0%</span>
          <span>10%</span>
        </div>
      </div>
      
      <div class="input-group" id="fixedGroup" style="display: none;">
        <div class="input-header">
          <label>Monthly Withdrawal</label>
          <span class="input-value" id="monthlyWithdrawalValue">$5,000</span>
        </div>
        <input type="range" id="monthlyWithdrawal" min="0" max="30000" step="500" value="5000">
        <div class="input-range">
          <span>$0</span>
          <span>$30,000</span>
        </div>
      </div>
    </div>
    
    <div class="chart-panel">
      <div class="metrics-grid">
        <div class="metric-card highlight">
          <span class="metric-label">Balance at Drawdown</span>
          <span class="metric-value" id="metricAtDrawdown">$0</span>
          <span class="metric-subtext" id="metricGrowthYears">After 0 years of growth</span>
        </div>
        <div class="metric-card">
          <span class="metric-label">Peak Balance</span>
          <span class="metric-value" id="metricPeak">$0</span>
          <span class="metric-subtext">Maximum portfolio value</span>
        </div>
        <div class="metric-card">
          <span class="metric-label">Total Withdrawn</span>
          <span class="metric-value" id="metricWithdrawn">$0</span>
          <span class="metric-subtext" id="metricYearsDrawdown">Over 0 years</span>
        </div>
        <div class="metric-card">
          <span class="metric-label">Final Status</span>
          <span class="metric-value" id="metricStatus">Sustainable</span>
          <span class="metric-subtext" id="metricStatusBadge"></span>
        </div>
      </div>
      
      <div class="chart-container">
        <canvas id="chart"></canvas>
      </div>
      
      <div class="chart-legend">
        <div class="legend-item">
          <div class="legend-dot" style="background: #6366f1;"></div>
          <span>Portfolio Balance</span>
        </div>
        <div class="legend-item">
          <div class="legend-dot" style="background: #10b981;"></div>
          <span>Annual Withdrawal</span>
        </div>
        <div class="legend-item">
          <div class="legend-dot growth"></div>
          <span id="legendGrowth">Growth Phase (Age 40–65)</span>
        </div>
        <div class="legend-item">
          <div class="legend-dot drawdown"></div>
          <span id="legendDrawdown">Drawdown Phase (Age 65+)</span>
        </div>
      </div>
    </div>
  </div>

  <!-- Aggressive Tab -->
  <div class="main-grid tab-content" id="aggressiveTab">
    <div class="controls-panel">
      <div class="controls-title">Parameters</div>
      
      <div class="input-group">
        <div class="input-header">
          <label>Starting Balance</label>
          <span class="input-value" id="aggStartingBalanceValue">$800,000</span>
        </div>
        <input type="range" id="aggStartingBalance" min="100000" max="5000000" step="50000" value="800000">
        <div class="input-range">
          <span>$100,000</span>
          <span>$5,000,000</span>
        </div>
      </div>
      
      <div class="input-group">
        <div class="input-header">
          <label>Current Age</label>
          <span class="input-value" id="aggCurrentAgeValue">43 yrs</span>
        </div>
        <input type="range" id="aggCurrentAge" min="20" max="70" step="1" value="43">
        <div class="input-range">
          <span>20 yrs</span>
          <span>70 yrs</span>
        </div>
      </div>
      
      <div class="input-group">
        <div class="input-header">
          <label>Age to Start Drawdown</label>
          <span class="input-value" id="aggDrawdownAgeValue">65 yrs</span>
        </div>
        <input type="range" id="aggDrawdownAge" min="21" max="80" step="1" value="65">
        <div class="input-range">
          <span>21 yrs</span>
          <span>80 yrs</span>
        </div>
      </div>
      
      <div class="input-group">
        <div class="input-header">
          <label>Annual Return Rate</label>
          <span class="input-value" id="aggAnnualReturnValue">7%</span>
        </div>
        <input type="range" id="aggAnnualReturn" min="0" max="15" step="0.5" value="7">
        <div class="input-range">
          <span>0%</span>
          <span>15%</span>
        </div>
      </div>
      
      <div class="controls-title" style="margin-top: 8px;">Target Strategy</div>
      
      <div class="strategy-note">
        Set your target age and desired ending balance. The calculator will determine the optimal annual withdrawal rate to achieve your goal.
      </div>
      
      <div class="input-group">
        <div class="input-header">
          <label>Target Depletion Age</label>
          <span class="input-value" id="aggDepletionAgeValue">90 yrs</span>
        </div>
        <input type="range" id="aggDepletionAge" min="70" max="100" step="1" value="90">
        <div class="input-range">
          <span>70 yrs</span>
          <span>100 yrs</span>
        </div>
      </div>
      
      <div class="input-group">
        <div class="input-header">
          <label>Target Ending Balance</label>
          <span class="input-value" id="aggEndingBalanceValue">$0</span>
        </div>
        <input type="range" id="aggEndingBalance" min="0" max="1000000" step="25000" value="0">
        <div class="input-range">
          <span>$0 (Fully Depleted)</span>
          <span>$1,000,000</span>
        </div>
      </div>
      
      <div class="calculated-rate">
        <span class="calculated-label">Calculated Withdrawal Rate</span>
        <span class="calculated-value" id="aggCalculatedRate">0%</span>
        <span class="calculated-sublabel">of balance per year</span>
      </div>
    </div>
    
    <div class="chart-panel">
      <div class="metrics-grid">
        <div class="metric-card highlight">
          <span class="metric-label">Balance at Drawdown</span>
          <span class="metric-value" id="aggMetricAtDrawdown">$0</span>
          <span class="metric-subtext" id="aggMetricGrowthYears">After 0 years of growth</span>
        </div>
        <div class="metric-card">
          <span class="metric-label">Peak Balance</span>
          <span class="metric-value" id="aggMetricPeak">$0</span>
          <span class="metric-subtext">Maximum portfolio value</span>
        </div>
        <div class="metric-card">
          <span class="metric-label">Total Withdrawn</span>
          <span class="metric-value" id="aggMetricWithdrawn">$0</span>
          <span class="metric-subtext" id="aggMetricYearsDrawdown">Over 0 years</span>
        </div>
        <div class="metric-card">
          <span class="metric-label">Final Status</span>
          <span class="metric-value" id="aggMetricStatus">Age 90</span>
          <span class="metric-subtext" id="aggMetricStatusBadge"></span>
        </div>
      </div>
      
      <div class="chart-container">
        <canvas id="aggChart"></canvas>
      </div>
      
      <div class="chart-legend">
        <div class="legend-item">
          <div class="legend-dot" style="background: #f59e0b;"></div>
          <span>Portfolio Balance</span>
        </div>
        <div class="legend-item">
          <div class="legend-dot" style="background: #ef4444;"></div>
          <span>Annual Withdrawal</span>
        </div>
        <div class="legend-item">
          <div class="legend-dot growth"></div>
          <span id="aggLegendGrowth">Growth Phase (Age 40–65)</span>
        </div>
        <div class="legend-item">
          <div class="legend-dot" style="background: #f59e0b;"></div>
          <span id="aggLegendDrawdown">Depletion Phase (Age 65–90)</span>
        </div>
      </div>
    </div>
  </div>

  <script>
    // LocalStorage keys
    const STORAGE_KEY_CONSERVATIVE = 'portfolio_conservative_state';
    const STORAGE_KEY_AGGRESSIVE = 'portfolio_aggressive_state';
    
    // Default values (born 1982 = 44 years old in 2026)
    const DEFAULT_STATE = {
      startingBalance: 800000,
      currentAge: 43,
      drawdownAge: 48,
      annualReturn: 7,
      drawdownPercent: 4,
      monthlyWithdrawal: 5000,
      usePercentage: true
    };
    
    const DEFAULT_AGG_STATE = {
      startingBalance: 800000,
      currentAge: 43,
      drawdownAge: 48,
      annualReturn: 7,
      depletionAge: 90,
      endingBalance: 0
    };
    
    // Load state from localStorage or use defaults
    function loadState() {
      try {
        const saved = localStorage.getItem(STORAGE_KEY_CONSERVATIVE);
        if (saved) {
          return { ...DEFAULT_STATE, ...JSON.parse(saved) };
        }
      } catch (e) {
        console.warn('Failed to load conservative state', e);
      }
      return { ...DEFAULT_STATE };
    }
    
    function loadAggState() {
      try {
        const saved = localStorage.getItem(STORAGE_KEY_AGGRESSIVE);
        if (saved) {
          return { ...DEFAULT_AGG_STATE, ...JSON.parse(saved) };
        }
      } catch (e) {
        console.warn('Failed to load aggressive state', e);
      }
      return { ...DEFAULT_AGG_STATE };
    }
    
    // Save state to localStorage
    function saveState() {
      try {
        localStorage.setItem(STORAGE_KEY_CONSERVATIVE, JSON.stringify(state));
      } catch (e) {
        console.warn('Failed to save conservative state', e);
      }
    }
    
    function saveAggState() {
      try {
        localStorage.setItem(STORAGE_KEY_AGGRESSIVE, JSON.stringify(aggState));
      } catch (e) {
        console.warn('Failed to save aggressive state', e);
      }
    }
    
    // State
    let state = loadState();

    // Chart instance
    let chart = null;

    // Formatters
    const formatCurrency = (value) => {
      if (value >= 1000000) return `$${(value / 1000000).toFixed(2)}M`;
      if (value >= 1000) return `$${(value / 1000).toFixed(0)}K`;
      return `$${value.toFixed(0)}`;
    };

    const formatFullCurrency = (value) => {
      return new Intl.NumberFormat('en-US', { style: 'currency', currency: 'USD', maximumFractionDigits: 0 }).format(value);
    };

    // Calculate projection data
    function calculateProjection() {
      const data = [];
      let balance = state.startingBalance;
      const monthlyReturn = state.annualReturn / 100 / 12;
      const maxAge = 100;
      
      for (let age = state.currentAge; age <= maxAge; age++) {
        let yearlyWithdrawal = 0;
        
        if (balance <= 0) {
          data.push({ age, balance: 0, withdrawal: 0 });
          break;
        }
        
        // Calculate this year's withdrawal before simulating
        if (age >= state.drawdownAge && balance > 0) {
          if (state.usePercentage) {
            // For percentage, we estimate based on start-of-year balance
            yearlyWithdrawal = balance * (state.drawdownPercent / 100);
          } else {
            yearlyWithdrawal = state.monthlyWithdrawal * 12;
          }
        }
        
        data.push({ age, balance: Math.max(0, balance), withdrawal: yearlyWithdrawal });
        
        for (let month = 0; month < 12; month++) {
          balance *= (1 + monthlyReturn);
          
          if (age >= state.drawdownAge) {
            if (state.usePercentage) {
              const monthlyDrawdown = (balance * (state.drawdownPercent / 100)) / 12;
              balance -= monthlyDrawdown;
            } else {
              balance -= state.monthlyWithdrawal;
            }
          }
        }
      }
      
      return data;
    }

    // Calculate metrics
    function calculateMetrics(data) {
      const peakBalance = Math.max(...data.map(d => d.balance));
      const atDrawdown = data.find(d => d.age === state.drawdownAge)?.balance || 0;
      const depleted = data.find(d => d.balance <= 0);
      const depletionAge = depleted ? depleted.age : null;
      const yearsInDrawdown = depletionAge ? depletionAge - state.drawdownAge : 100 - state.drawdownAge;
      
      let totalWithdrawn = 0;
      data.forEach((d) => {
        if (d.age >= state.drawdownAge && d.balance > 0) {
          if (state.usePercentage) {
            totalWithdrawn += d.balance * (state.drawdownPercent / 100);
          } else {
            totalWithdrawn += state.monthlyWithdrawal * 12;
          }
        }
      });

      return {
        peakBalance,
        atDrawdown,
        depletionAge,
        yearsInDrawdown,
        totalWithdrawn,
        growthYears: state.drawdownAge - state.currentAge
      };
    }

    // Update chart
    function updateChart() {
      const data = calculateProjection();
      const metrics = calculateMetrics(data);
      
      // Update metrics display
      document.getElementById('metricAtDrawdown').textContent = formatCurrency(metrics.atDrawdown);
      document.getElementById('metricGrowthYears').textContent = `After ${metrics.growthYears} years of growth`;
      document.getElementById('metricPeak').textContent = formatCurrency(metrics.peakBalance);
      document.getElementById('metricWithdrawn').textContent = formatCurrency(metrics.totalWithdrawn);
      document.getElementById('metricYearsDrawdown').textContent = `Over ${metrics.yearsInDrawdown} years`;
      
      if (metrics.depletionAge) {
        document.getElementById('metricStatus').textContent = `Depletes at ${metrics.depletionAge}`;
        document.getElementById('metricStatusBadge').innerHTML = '<span class="warning-badge">⚠ Runs out</span>';
      } else {
        document.getElementById('metricStatus').textContent = 'Sustainable';
        document.getElementById('metricStatusBadge').innerHTML = '<span class="success-badge">✓ Lasts to 100</span>';
      }
      
      // Update legend
      document.getElementById('legendGrowth').textContent = `Growth Phase (Age ${state.currentAge}–${state.drawdownAge})`;
      document.getElementById('legendDrawdown').textContent = `Drawdown Phase (Age ${state.drawdownAge}+)`;
      
      // Update or create chart
      const labels = data.map(d => d.age);
      const values = data.map(d => d.balance);
      const withdrawals = data.map(d => d.withdrawal);
      
      // Create gradient
      const ctx = document.getElementById('chart').getContext('2d');

      if (chart) {
        chart.data.labels = labels;
        chart.data.datasets[0].data = values;
        chart.data.datasets[1].data = withdrawals;
        chart.update('none');
      } else {
        chart = new Chart(ctx, {
          type: 'line',
          data: {
            labels: labels,
            datasets: [
              {
                label: 'Portfolio Balance',
                data: values,
                borderColor: '#6366f1',
                backgroundColor: 'rgba(99, 102, 241, 0.15)',
                borderWidth: 2.5,
                fill: '+1',
                tension: 0.3,
                pointRadius: 0,
                pointHoverRadius: 6,
                pointHoverBackgroundColor: '#6366f1',
                pointHoverBorderColor: '#fff',
                pointHoverBorderWidth: 2
              },
              {
                label: 'Annual Withdrawal',
                data: withdrawals,
                borderColor: '#10b981',
                backgroundColor: 'transparent',
                borderWidth: 2,
                fill: false,
                tension: 0.3,
                pointRadius: 0,
                pointHoverRadius: 5,
                pointHoverBackgroundColor: '#10b981',
                pointHoverBorderColor: '#fff',
                pointHoverBorderWidth: 2,
                borderDash: [5, 5]
              }
            ]
          },
          options: {
            responsive: true,
            maintainAspectRatio: false,
            interaction: {
              intersect: false,
              mode: 'index'
            },
            plugins: {
              legend: { display: false },
              tooltip: {
                backgroundColor: 'rgba(20, 20, 22, 0.95)',
                borderColor: '#333',
                borderWidth: 1,
                titleFont: { family: 'Space Mono', size: 11 },
                titleColor: '#666',
                bodyFont: { family: 'Space Mono', size: 14, weight: 'bold' },
                bodyColor: '#fff',
                padding: 14,
                cornerRadius: 10,
                displayColors: true,
                callbacks: {
                  title: (items) => `Age ${items[0].label}`,
                  label: (item) => {
                    const label = item.dataset.label;
                    const value = formatFullCurrency(item.raw);
                    return `${label}: ${value}`;
                  },
                  afterBody: (items) => {
                    const idx = items[0].dataIndex;
                    const bal = values[idx] || 0;
                    const wth = withdrawals[idx] || 0;
                    const diff = bal - wth;
                    const phase = items[0].label >= state.drawdownAge ? 'Drawdown' : 'Growth';
                    return `\nDifference: ${formatFullCurrency(diff)}\n${phase} Phase`;
                  }
                }
              }
            },
            scales: {
              x: {
                grid: { color: '#222', drawBorder: false },
                ticks: { 
                  color: '#555', 
                  font: { family: 'Space Mono', size: 11 }
                },
                title: {
                  display: true,
                  text: 'Age',
                  color: '#444',
                  font: { family: 'Space Mono', size: 11 }
                }
              },
              y: {
                type: 'linear',
                display: true,
                position: 'left',
                grid: { color: '#222', drawBorder: false },
                ticks: { 
                  color: '#888', 
                  font: { family: 'Space Mono', size: 11 },
                  callback: (value) => formatCurrency(value)
                },
                title: {
                  display: true,
                  text: 'Amount',
                  color: '#888',
                  font: { family: 'Space Mono', size: 10 }
                },
                beginAtZero: true
              }
            }
          }
        });
      }
    }

    // Event listeners
    function setupListeners() {
      // Starting Balance
      document.getElementById('startingBalance').addEventListener('input', (e) => {
        state.startingBalance = parseFloat(e.target.value);
        document.getElementById('startingBalanceValue').textContent = formatFullCurrency(state.startingBalance);
        saveState();
        updateChart();
      });

      // Current Age
      document.getElementById('currentAge').addEventListener('input', (e) => {
        state.currentAge = parseInt(e.target.value);
        document.getElementById('currentAgeValue').textContent = `${state.currentAge} yrs`;
        
        // Ensure drawdown age is always greater than current age
        if (state.drawdownAge < state.currentAge) {
          state.drawdownAge = state.currentAge;
          document.getElementById('drawdownAge').value = state.drawdownAge;
          document.getElementById('drawdownAgeValue').textContent = `${state.drawdownAge} yrs`;
        }
        document.getElementById('drawdownAge').min = state.currentAge;
        
        saveState();
        updateChart();
      });

      // Drawdown Age
      document.getElementById('drawdownAge').addEventListener('input', (e) => {
        state.drawdownAge = Math.max(parseInt(e.target.value), state.currentAge);
        document.getElementById('drawdownAgeValue').textContent = `${state.drawdownAge} yrs`;
        saveState();
        updateChart();
      });

      // Annual Return
      document.getElementById('annualReturn').addEventListener('input', (e) => {
        state.annualReturn = parseFloat(e.target.value);
        document.getElementById('annualReturnValue').textContent = `${state.annualReturn}%`;
        saveState();
        updateChart();
      });

      // Drawdown Percent
      document.getElementById('drawdownPercent').addEventListener('input', (e) => {
        state.drawdownPercent = parseFloat(e.target.value);
        document.getElementById('drawdownPercentValue').textContent = `${state.drawdownPercent}%`;
        saveState();
        updateChart();
      });

      // Monthly Withdrawal
      document.getElementById('monthlyWithdrawal').addEventListener('input', (e) => {
        state.monthlyWithdrawal = parseFloat(e.target.value);
        document.getElementById('monthlyWithdrawalValue').textContent = formatFullCurrency(state.monthlyWithdrawal);
        saveState();
        updateChart();
      });

      // Toggle buttons
      document.getElementById('togglePercent').addEventListener('click', () => {
        state.usePercentage = true;
        document.getElementById('togglePercent').classList.add('active');
        document.getElementById('toggleFixed').classList.remove('active');
        document.getElementById('percentGroup').style.display = 'block';
        document.getElementById('fixedGroup').style.display = 'none';
        saveState();
        updateChart();
      });

      document.getElementById('toggleFixed').addEventListener('click', () => {
        state.usePercentage = false;
        document.getElementById('toggleFixed').classList.add('active');
        document.getElementById('togglePercent').classList.remove('active');
        document.getElementById('fixedGroup').style.display = 'block';
        document.getElementById('percentGroup').style.display = 'none';
        saveState();
        updateChart();
      });
    }

    // Initialize
    document.addEventListener('DOMContentLoaded', () => {
      setupListeners();
      syncConservativeUI();
      updateChart();
      setupAggressiveListeners();
      syncAggressiveUI();
      updateAggressiveChart();
      setupTabListeners();
      setupDefaultButton();
    });
    
    // Sync conservative UI with state
    function syncConservativeUI() {
      document.getElementById('startingBalance').value = state.startingBalance;
      document.getElementById('startingBalanceValue').textContent = formatFullCurrency(state.startingBalance);
      
      document.getElementById('currentAge').value = state.currentAge;
      document.getElementById('currentAgeValue').textContent = `${state.currentAge} yrs`;
      
      document.getElementById('drawdownAge').value = state.drawdownAge;
      document.getElementById('drawdownAge').min = state.currentAge;
      document.getElementById('drawdownAgeValue').textContent = `${state.drawdownAge} yrs`;
      
      document.getElementById('annualReturn').value = state.annualReturn;
      document.getElementById('annualReturnValue').textContent = `${state.annualReturn}%`;
      
      document.getElementById('drawdownPercent').value = state.drawdownPercent;
      document.getElementById('drawdownPercentValue').textContent = `${state.drawdownPercent}%`;
      
      document.getElementById('monthlyWithdrawal').value = state.monthlyWithdrawal;
      document.getElementById('monthlyWithdrawalValue').textContent = formatFullCurrency(state.monthlyWithdrawal);
      
      if (state.usePercentage) {
        document.getElementById('togglePercent').classList.add('active');
        document.getElementById('toggleFixed').classList.remove('active');
        document.getElementById('percentGroup').style.display = 'block';
        document.getElementById('fixedGroup').style.display = 'none';
      } else {
        document.getElementById('toggleFixed').classList.add('active');
        document.getElementById('togglePercent').classList.remove('active');
        document.getElementById('fixedGroup').style.display = 'block';
        document.getElementById('percentGroup').style.display = 'none';
      }
    }
    
    // Sync aggressive UI with state
    function syncAggressiveUI() {
      document.getElementById('aggStartingBalance').value = aggState.startingBalance;
      document.getElementById('aggStartingBalanceValue').textContent = formatFullCurrency(aggState.startingBalance);
      
      document.getElementById('aggCurrentAge').value = aggState.currentAge;
      document.getElementById('aggCurrentAgeValue').textContent = `${aggState.currentAge} yrs`;
      
      document.getElementById('aggDrawdownAge').value = aggState.drawdownAge;
      document.getElementById('aggDrawdownAge').min = aggState.currentAge;
      document.getElementById('aggDrawdownAgeValue').textContent = `${aggState.drawdownAge} yrs`;
      
      document.getElementById('aggAnnualReturn').value = aggState.annualReturn;
      document.getElementById('aggAnnualReturnValue').textContent = `${aggState.annualReturn}%`;
      
      document.getElementById('aggDepletionAge').value = aggState.depletionAge;
      document.getElementById('aggDepletionAge').min = aggState.drawdownAge + 1;
      document.getElementById('aggDepletionAgeValue').textContent = `${aggState.depletionAge} yrs`;
      
      document.getElementById('aggEndingBalance').value = aggState.endingBalance;
      document.getElementById('aggEndingBalanceValue').textContent = aggState.endingBalance === 0 ? '$0' : formatFullCurrency(aggState.endingBalance);
    }
    
    // Default button handler
    function setupDefaultButton() {
      document.getElementById('btnDefault').addEventListener('click', () => {
        // Reset conservative state
        state = { ...DEFAULT_STATE };
        saveState();
        syncConservativeUI();
        updateChart();
        
        // Reset aggressive state
        aggState = { ...DEFAULT_AGG_STATE };
        saveAggState();
        syncAggressiveUI();
        updateAggressiveChart();
      });
    }
    
    // =====================
    // AGGRESSIVE TAB LOGIC
    // =====================
    
    let aggState = loadAggState();
    
    let aggChart = null;
    
    // Calculate optimal withdrawal rate to reach target ending balance by target age
    function calculateOptimalRate() {
      const { startingBalance, currentAge, drawdownAge, annualReturn, depletionAge, endingBalance } = aggState;
      const monthlyReturn = annualReturn / 100 / 12;
      
      // First, calculate balance at drawdown age
      let balanceAtDrawdown = startingBalance;
      for (let age = currentAge; age < drawdownAge; age++) {
        for (let month = 0; month < 12; month++) {
          balanceAtDrawdown *= (1 + monthlyReturn);
        }
      }
      
      // Binary search for the withdrawal rate that reaches target ending balance by target age
      let low = 0;
      let high = 50; // Max 50% withdrawal rate
      let optimalRate = 0;
      
      for (let i = 0; i < 50; i++) { // 50 iterations for precision
        const mid = (low + high) / 2;
        const finalBalance = simulateFinalBalance(balanceAtDrawdown, mid, annualReturn, depletionAge - drawdownAge);
        
        if (finalBalance < endingBalance) {
          high = mid; // Rate too high, ending balance too low
        } else {
          low = mid; // Rate too low, ending balance too high
          optimalRate = mid;
        }
      }
      
      return optimalRate;
    }
    
    // Simulate final balance after given years at given withdrawal rate
    function simulateFinalBalance(startBalance, withdrawalRate, annualReturn, years) {
      let balance = startBalance;
      const monthlyReturn = annualReturn / 100 / 12;
      
      for (let year = 0; year < years; year++) {
        for (let month = 0; month < 12; month++) {
          balance *= (1 + monthlyReturn);
          const monthlyWithdrawal = (balance * (withdrawalRate / 100)) / 12;
          balance -= monthlyWithdrawal;
        }
        if (balance < 0) return 0;
      }
      
      return Math.max(0, balance);
    }
    
    // Calculate aggressive projection data
    function calculateAggressiveProjection(withdrawalRate) {
      const data = [];
      let balance = aggState.startingBalance;
      const monthlyReturn = aggState.annualReturn / 100 / 12;
      const targetEndingBalance = aggState.endingBalance;
      
      for (let age = aggState.currentAge; age <= aggState.depletionAge + 2; age++) {
        let yearlyWithdrawal = 0;
        
        if (balance <= targetEndingBalance && age > aggState.drawdownAge) {
          data.push({ age, balance: Math.max(0, balance), withdrawal: 0 });
          continue;
        }
        
        if (age >= aggState.drawdownAge && balance > 0) {
          yearlyWithdrawal = balance * (withdrawalRate / 100);
        }
        
        data.push({ age, balance: Math.max(0, balance), withdrawal: yearlyWithdrawal });
        
        for (let month = 0; month < 12; month++) {
          balance *= (1 + monthlyReturn);
          
          if (age >= aggState.drawdownAge) {
            const monthlyDrawdown = (balance * (withdrawalRate / 100)) / 12;
            balance -= monthlyDrawdown;
          }
        }
      }
      
      return data;
    }
    
    // Calculate aggressive metrics
    function calculateAggressiveMetrics(data, withdrawalRate) {
      const peakBalance = Math.max(...data.map(d => d.balance));
      const atDrawdown = data.find(d => d.age === aggState.drawdownAge)?.balance || 0;
      const atTargetAge = data.find(d => d.age === aggState.depletionAge)?.balance || 0;
      
      let totalWithdrawn = 0;
      data.forEach((d) => {
        if (d.age >= aggState.drawdownAge && d.balance > 0) {
          totalWithdrawn += d.withdrawal;
        }
      });

      return {
        peakBalance,
        atDrawdown,
        finalBalance: atTargetAge,
        totalWithdrawn,
        growthYears: aggState.drawdownAge - aggState.currentAge,
        yearsInDrawdown: aggState.depletionAge - aggState.drawdownAge
      };
    }
    
    // Update aggressive chart
    function updateAggressiveChart() {
      const withdrawalRate = calculateOptimalRate();
      const data = calculateAggressiveProjection(withdrawalRate);
      const metrics = calculateAggressiveMetrics(data, withdrawalRate);
      
      // Update calculated rate display
      document.getElementById('aggCalculatedRate').textContent = `${withdrawalRate.toFixed(1)}%`;
      
      // Update metrics display
      document.getElementById('aggMetricAtDrawdown').textContent = formatCurrency(metrics.atDrawdown);
      document.getElementById('aggMetricGrowthYears').textContent = `After ${metrics.growthYears} years of growth`;
      document.getElementById('aggMetricPeak').textContent = formatCurrency(metrics.peakBalance);
      document.getElementById('aggMetricWithdrawn').textContent = formatCurrency(metrics.totalWithdrawn);
      document.getElementById('aggMetricYearsDrawdown').textContent = `Over ${metrics.yearsInDrawdown} years`;
      
      // Update final balance metric
      const targetEndingBalance = aggState.endingBalance;
      if (targetEndingBalance === 0) {
        document.getElementById('aggMetricStatus').textContent = `Depleted at ${aggState.depletionAge}`;
        document.getElementById('aggMetricStatusBadge').innerHTML = '<span class="depleted-badge">🎯 Fully spent</span>';
      } else {
        document.getElementById('aggMetricStatus').textContent = formatCurrency(metrics.finalBalance);
        document.getElementById('aggMetricStatusBadge').innerHTML = `<span class="depleted-badge">🎯 Left at age ${aggState.depletionAge}</span>`;
      }
      
      // Update legend
      document.getElementById('aggLegendGrowth').textContent = `Growth Phase (Age ${aggState.currentAge}–${aggState.drawdownAge})`;
      document.getElementById('aggLegendDrawdown').textContent = `Drawdown Phase (Age ${aggState.drawdownAge}–${aggState.depletionAge})`;
      
      // Update or create chart
      const labels = data.map(d => d.age);
      const values = data.map(d => d.balance);
      const withdrawals = data.map(d => d.withdrawal);
      
      const ctx = document.getElementById('aggChart').getContext('2d');

      if (aggChart) {
        aggChart.data.labels = labels;
        aggChart.data.datasets[0].data = values;
        aggChart.data.datasets[1].data = withdrawals;
        aggChart.update('none');
      } else {
        aggChart = new Chart(ctx, {
          type: 'line',
          data: {
            labels: labels,
            datasets: [
              {
                label: 'Portfolio Balance',
                data: values,
                borderColor: '#f59e0b',
                backgroundColor: 'rgba(245, 158, 11, 0.15)',
                borderWidth: 2.5,
                fill: '+1',
                tension: 0.3,
                pointRadius: 0,
                pointHoverRadius: 6,
                pointHoverBackgroundColor: '#f59e0b',
                pointHoverBorderColor: '#fff',
                pointHoverBorderWidth: 2
              },
              {
                label: 'Annual Withdrawal',
                data: withdrawals,
                borderColor: '#ef4444',
                backgroundColor: 'transparent',
                borderWidth: 2,
                fill: false,
                tension: 0.3,
                pointRadius: 0,
                pointHoverRadius: 5,
                pointHoverBackgroundColor: '#ef4444',
                pointHoverBorderColor: '#fff',
                pointHoverBorderWidth: 2,
                borderDash: [5, 5]
              }
            ]
          },
          options: {
            responsive: true,
            maintainAspectRatio: false,
            interaction: {
              intersect: false,
              mode: 'index'
            },
            plugins: {
              legend: { display: false },
              tooltip: {
                backgroundColor: 'rgba(20, 20, 22, 0.95)',
                borderColor: '#333',
                borderWidth: 1,
                titleFont: { family: 'Space Mono', size: 11 },
                titleColor: '#666',
                bodyFont: { family: 'Space Mono', size: 14, weight: 'bold' },
                bodyColor: '#fff',
                padding: 14,
                cornerRadius: 10,
                displayColors: true,
                callbacks: {
                  title: (items) => `Age ${items[0].label}`,
                  label: (item) => {
                    const label = item.dataset.label;
                    const value = formatFullCurrency(item.raw);
                    return `${label}: ${value}`;
                  },
                  afterBody: (items) => {
                    const idx = items[0].dataIndex;
                    const bal = values[idx] || 0;
                    const wth = withdrawals[idx] || 0;
                    const diff = bal - wth;
                    const age = parseInt(items[0].label);
                    const phase = age < aggState.drawdownAge ? 'Growth' : 'Depletion';
                    return `\nDifference: ${formatFullCurrency(diff)}\n${phase} Phase`;
                  }
                }
              }
            },
            scales: {
              x: {
                grid: { color: '#222', drawBorder: false },
                ticks: { 
                  color: '#555', 
                  font: { family: 'Space Mono', size: 11 }
                },
                title: {
                  display: true,
                  text: 'Age',
                  color: '#444',
                  font: { family: 'Space Mono', size: 11 }
                }
              },
              y: {
                type: 'linear',
                display: true,
                position: 'left',
                grid: { color: '#222', drawBorder: false },
                ticks: { 
                  color: '#888', 
                  font: { family: 'Space Mono', size: 11 },
                  callback: (value) => formatCurrency(value)
                },
                title: {
                  display: true,
                  text: 'Amount',
                  color: '#888',
                  font: { family: 'Space Mono', size: 10 }
                },
                beginAtZero: true
              }
            }
          }
        });
      }
    }
    
    // Setup aggressive tab listeners
    function setupAggressiveListeners() {
      document.getElementById('aggStartingBalance').addEventListener('input', (e) => {
        aggState.startingBalance = parseFloat(e.target.value);
        document.getElementById('aggStartingBalanceValue').textContent = formatFullCurrency(aggState.startingBalance);
        saveAggState();
        updateAggressiveChart();
      });

      document.getElementById('aggCurrentAge').addEventListener('input', (e) => {
        aggState.currentAge = parseInt(e.target.value);
        document.getElementById('aggCurrentAgeValue').textContent = `${aggState.currentAge} yrs`;
        
        if (aggState.drawdownAge < aggState.currentAge) {
          aggState.drawdownAge = aggState.currentAge;
          document.getElementById('aggDrawdownAge').value = aggState.drawdownAge;
          document.getElementById('aggDrawdownAgeValue').textContent = `${aggState.drawdownAge} yrs`;
        }
        document.getElementById('aggDrawdownAge').min = aggState.currentAge;
        
        if (aggState.depletionAge <= aggState.drawdownAge) {
          aggState.depletionAge = aggState.drawdownAge + 5;
          document.getElementById('aggDepletionAge').value = aggState.depletionAge;
          document.getElementById('aggDepletionAgeValue').textContent = `${aggState.depletionAge} yrs`;
        }
        document.getElementById('aggDepletionAge').min = aggState.drawdownAge + 1;
        
        saveAggState();
        updateAggressiveChart();
      });

      document.getElementById('aggDrawdownAge').addEventListener('input', (e) => {
        aggState.drawdownAge = Math.max(parseInt(e.target.value), aggState.currentAge);
        document.getElementById('aggDrawdownAgeValue').textContent = `${aggState.drawdownAge} yrs`;
        
        if (aggState.depletionAge <= aggState.drawdownAge) {
          aggState.depletionAge = aggState.drawdownAge + 5;
          document.getElementById('aggDepletionAge').value = aggState.depletionAge;
          document.getElementById('aggDepletionAgeValue').textContent = `${aggState.depletionAge} yrs`;
        }
        document.getElementById('aggDepletionAge').min = aggState.drawdownAge + 1;
        
        saveAggState();
        updateAggressiveChart();
      });

      document.getElementById('aggAnnualReturn').addEventListener('input', (e) => {
        aggState.annualReturn = parseFloat(e.target.value);
        document.getElementById('aggAnnualReturnValue').textContent = `${aggState.annualReturn}%`;
        saveAggState();
        updateAggressiveChart();
      });

      document.getElementById('aggDepletionAge').addEventListener('input', (e) => {
        aggState.depletionAge = Math.max(parseInt(e.target.value), aggState.drawdownAge + 1);
        document.getElementById('aggDepletionAgeValue').textContent = `${aggState.depletionAge} yrs`;
        saveAggState();
        updateAggressiveChart();
      });
      
      document.getElementById('aggEndingBalance').addEventListener('input', (e) => {
        aggState.endingBalance = parseFloat(e.target.value);
        document.getElementById('aggEndingBalanceValue').textContent = aggState.endingBalance === 0 ? '$0' : formatFullCurrency(aggState.endingBalance);
        saveAggState();
        updateAggressiveChart();
      });
    }
    
    // Tab switching
    function setupTabListeners() {
      document.getElementById('tabConservative').addEventListener('click', () => {
        document.getElementById('tabConservative').classList.add('active');
        document.getElementById('tabAggressive').classList.remove('active');
        document.getElementById('conservativeTab').classList.add('active');
        document.getElementById('aggressiveTab').classList.remove('active');
      });
      
      document.getElementById('tabAggressive').addEventListener('click', () => {
        document.getElementById('tabAggressive').classList.add('active');
        document.getElementById('tabConservative').classList.remove('active');
        document.getElementById('aggressiveTab').classList.add('active');
        document.getElementById('conservativeTab').classList.remove('active');
        // Refresh chart when switching to aggressive tab
        setTimeout(() => {
          if (aggChart) {
            aggChart.resize();
          }
        }, 50);
      });
    }
  </script>
</body>
</html>
