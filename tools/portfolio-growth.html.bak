<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Portfolio Growth Visualizer</title>
  <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.1/dist/chart.umd.min.js"></script>
  <link href="https://fonts.googleapis.com/css2?family=DM+Sans:opsz,wght@9..40,300;9..40,400;9..40,500;9..40,600&family=Space+Mono:wght@400;700&display=swap" rel="stylesheet">
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    
    body {
      min-height: 100vh;
      background: #0a0a0b;
      color: #e8e8e8;
      font-family: 'DM Sans', sans-serif;
      padding: 0 40px 40px;
      background-image: 
        radial-gradient(ellipse at 20% 0%, rgba(16, 185, 129, 0.08) 0%, transparent 50%),
        radial-gradient(ellipse at 80% 100%, rgba(99, 102, 241, 0.06) 0%, transparent 50%);
    }
    
    .header {
      max-width: 1400px;
      margin: 0 auto 48px;
      animation: fadeIn 0.6s ease-out;
    }
    
    @keyframes fadeIn {
      from { opacity: 0; transform: translateY(-10px); }
      to { opacity: 1; transform: translateY(0); }
    }
    
    .header h1 {
      font-family: 'Space Mono', monospace;
      font-size: 32px;
      font-weight: 700;
      letter-spacing: -1px;
      margin-bottom: 8px;
      background: linear-gradient(135deg, #fff 0%, #a5a5a5 100%);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
    }
    
    .header p { color: #666; font-size: 15px; letter-spacing: 0.5px; }

    .header-actions {
      display: flex;
      gap: 8px;
      margin-top: 24px;
      align-items: center;
    }

    .tab-btn {
      padding: 12px 24px;
      background: #1a1a1c;
      border: 1px solid #333;
      color: #666;
      font-family: 'Space Mono', monospace;
      font-size: 13px;
      font-weight: 700;
      cursor: pointer;
      border-radius: 8px;
      transition: all 0.2s ease;
    }
    
    .tab-btn:hover { border-color: #444; color: #888; }
    
    .tab-btn.active {
      background: linear-gradient(135deg, #10b981 0%, #059669 100%);
      border-color: transparent;
      color: #fff;
      box-shadow: 0 2px 12px rgba(16, 185, 129, 0.3);
    }

    .default-btn {
      padding: 12px 24px;
      background: transparent;
      border: 1px dashed #444;
      color: #666;
      font-family: 'Space Mono', monospace;
      font-size: 13px;
      font-weight: 700;
      cursor: pointer;
      border-radius: 8px;
      transition: all 0.2s ease;
      margin-left: auto;
    }
    
    .default-btn:hover {
      border-color: #10b981;
      color: #10b981;
      background: rgba(16, 185, 129, 0.1);
    }
    
    .main-grid {
      max-width: 1400px;
      margin: 0 auto;
      display: grid;
      grid-template-columns: 340px 1fr;
      gap: 32px;
      animation: fadeIn 0.8s ease-out 0.1s both;
    }
    
    .controls-panel {
      background: linear-gradient(145deg, #141416 0%, #0f0f10 100%);
      border: 1px solid #222;
      border-radius: 20px;
      padding: 28px;
      height: fit-content;
      position: sticky;
      top: 40px;
    }
    
    .controls-title {
      font-family: 'Space Mono', monospace;
      font-size: 11px;
      text-transform: uppercase;
      letter-spacing: 2px;
      color: #555;
      margin-bottom: 24px;
      padding-bottom: 16px;
      border-bottom: 1px solid #222;
    }
    
    .input-group { margin-bottom: 28px; }
    
    .input-header {
      display: flex;
      justify-content: space-between;
      align-items: baseline;
      margin-bottom: 12px;
    }
    
    .input-header label { font-size: 13px; color: #888; font-weight: 500; }
    
    .input-value {
      font-family: 'Space Mono', monospace;
      font-size: 16px;
      font-weight: 700;
      color: #fff;
    }
    
    input[type="range"] {
      width: 100%;
      height: 6px;
      -webkit-appearance: none;
      background: #222;
      border-radius: 3px;
      outline: none;
      cursor: pointer;
    }
    
    input[type="range"]::-webkit-slider-thumb {
      -webkit-appearance: none;
      width: 18px;
      height: 18px;
      background: linear-gradient(135deg, #10b981 0%, #059669 100%);
      border-radius: 50%;
      cursor: pointer;
      box-shadow: 0 2px 8px rgba(16, 185, 129, 0.4);
      transition: transform 0.15s ease, box-shadow 0.15s ease;
    }
    
    input[type="range"]::-webkit-slider-thumb:hover {
      transform: scale(1.1);
      box-shadow: 0 4px 12px rgba(16, 185, 129, 0.5);
    }
    
    input[type="range"]::-moz-range-thumb {
      width: 18px;
      height: 18px;
      background: linear-gradient(135deg, #10b981 0%, #059669 100%);
      border-radius: 50%;
      cursor: pointer;
      border: none;
      box-shadow: 0 2px 8px rgba(16, 185, 129, 0.4);
    }
    
    .input-range {
      display: flex;
      justify-content: space-between;
      margin-top: 8px;
      font-size: 10px;
      color: #444;
      font-family: 'Space Mono', monospace;
    }
    
    .toggle-group {
      display: flex;
      background: #1a1a1c;
      border-radius: 10px;
      padding: 4px;
      margin-bottom: 24px;
    }
    
    .toggle-btn {
      flex: 1;
      padding: 10px 12px;
      background: transparent;
      border: none;
      color: #666;
      font-size: 12px;
      font-family: 'DM Sans', sans-serif;
      font-weight: 500;
      cursor: pointer;
      border-radius: 8px;
      transition: all 0.2s ease;
    }
    
    .toggle-btn.active {
      background: linear-gradient(135deg, #10b981 0%, #059669 100%);
      color: #fff;
      box-shadow: 0 2px 8px rgba(16, 185, 129, 0.3);
    }
    
    .chart-panel {
      background: linear-gradient(145deg, #141416 0%, #0f0f10 100%);
      border: 1px solid #222;
      border-radius: 20px;
      padding: 28px;
    }
    
    .metrics-grid {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 16px;
      margin-bottom: 32px;
    }
    
    .metric-card {
      background: #1a1a1c;
      border: 1px solid #252528;
      border-radius: 12px;
      padding: 18px;
      display: flex;
      flex-direction: column;
      transition: transform 0.2s ease, border-color 0.2s ease;
    }
    
    .metric-card:hover { transform: translateY(-2px); border-color: #333; }
    
    .metric-card.highlight {
      background: linear-gradient(145deg, rgba(16, 185, 129, 0.1) 0%, rgba(16, 185, 129, 0.05) 100%);
      border-color: rgba(16, 185, 129, 0.3);
    }
    
    .metric-label {
      font-size: 11px;
      text-transform: uppercase;
      letter-spacing: 1px;
      color: #555;
      margin-bottom: 8px;
      font-weight: 500;
    }
    
    .metric-value {
      font-family: 'Space Mono', monospace;
      font-size: 20px;
      font-weight: 700;
      color: #fff;
    }
    
    .metric-card.highlight .metric-value {
      background: linear-gradient(135deg, #10b981 0%, #34d399 100%);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
    }
    
    .metric-subtext { font-size: 11px; color: #444; margin-top: 6px; }
    
    .chart-container { height: 420px; margin-top: 8px; position: relative; }
    
    .chart-legend {
      display: flex;
      justify-content: center;
      gap: 32px;
      flex-wrap: wrap;
      margin-top: 20px;
    }
    
    .legend-item { display: flex; align-items: center; gap: 8px; font-size: 12px; color: #666; }
    .legend-dot { width: 10px; height: 10px; border-radius: 50%; }

    /* Stage cards for advanced mode */
    .stage-card {
      background: #1a1a1c;
      border: 1px solid #252528;
      border-radius: 12px;
      padding: 16px;
      margin-bottom: 16px;
      position: relative;
    }

    .stage-card .stage-header {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-bottom: 14px;
    }

    .stage-label {
      font-family: 'Space Mono', monospace;
      font-size: 11px;
      text-transform: uppercase;
      letter-spacing: 1.5px;
      color: #10b981;
      font-weight: 700;
    }

    .stage-remove {
      background: none;
      border: 1px solid #333;
      color: #555;
      width: 24px;
      height: 24px;
      border-radius: 6px;
      cursor: pointer;
      font-size: 14px;
      display: flex;
      align-items: center;
      justify-content: center;
      transition: all 0.2s;
    }

    .stage-remove:hover {
      border-color: #ef4444;
      color: #ef4444;
      background: rgba(239, 68, 68, 0.1);
    }

    .stage-card .input-group { margin-bottom: 16px; }
    .stage-card .input-group:last-child { margin-bottom: 0; }

    .stage-card .input-header { margin-bottom: 8px; }
    .stage-card .input-header label { font-size: 12px; }
    .stage-card .input-value { font-size: 14px; }

    .add-stage-btn {
      width: 100%;
      padding: 12px;
      background: transparent;
      border: 1px dashed #333;
      color: #555;
      font-family: 'Space Mono', monospace;
      font-size: 12px;
      font-weight: 700;
      cursor: pointer;
      border-radius: 10px;
      transition: all 0.2s ease;
      margin-bottom: 8px;
    }

    .add-stage-btn:hover {
      border-color: #10b981;
      color: #10b981;
      background: rgba(16, 185, 129, 0.05);
    }

    .stage-freq-toggle {
      display: flex;
      background: #141416;
      border-radius: 8px;
      padding: 3px;
      margin-bottom: 12px;
    }

    .stage-freq-btn {
      flex: 1;
      padding: 6px 8px;
      background: transparent;
      border: none;
      color: #555;
      font-size: 11px;
      font-family: 'DM Sans', sans-serif;
      font-weight: 500;
      cursor: pointer;
      border-radius: 6px;
      transition: all 0.2s ease;
    }

    .stage-freq-btn.active {
      background: linear-gradient(135deg, #10b981 0%, #059669 100%);
      color: #fff;
    }
    
    @media (max-width: 1200px) {
      .main-grid { grid-template-columns: 1fr; }
      .controls-panel { position: static; }
      .metrics-grid { grid-template-columns: repeat(2, 1fr); }
    }
    
    @media (max-width: 600px) {
      body { padding: 0 16px 24px; }
      nav { padding: 12px 0 12px !important; height: auto !important; }
      .header h1 { font-size: 22px; }
      .header p { font-size: 13px; }
      .header-actions { flex-wrap: wrap; }
      .tab-btn, .default-btn { padding: 10px 16px; font-size: 12px; }
      .default-btn { margin-left: 0; }
      .controls-panel { padding: 20px; border-radius: 14px; }
      .chart-panel { padding: 16px; border-radius: 14px; }
      .metrics-grid { grid-template-columns: 1fr 1fr; gap: 10px; }
      .metric-card { padding: 12px; }
      .metric-value { font-size: 16px; }
      .chart-container { height: 280px; }
    }
  </style>
</head>
<body>
  <nav style="max-width:1400px;margin:0 auto;padding:20px 0 16px;display:flex;align-items:center;height:56px;">
    <a href="/" style="color:#555;text-decoration:none;font-size:14px;font-family:-apple-system,BlinkMacSystemFont,sans-serif;display:inline-flex;align-items:center;gap:6px;transition:color 0.2s;" onmouseover="this.style.color='#fff'" onmouseout="this.style.color='#555'">← Tamation</a>
  </nav>
  
  <header class="header">
    <h1>Portfolio Growth Visualizer</h1>
    <p>Model your portfolio growth with regular contributions over time</p>
    <div class="header-actions">
      <button class="tab-btn active" id="tabBasic">Basic</button>
      <button class="tab-btn" id="tabAdvanced">Advanced</button>
      <button class="default-btn" id="btnDefault">Reset Defaults</button>
    </div>
  </header>
  
  <div class="main-grid">
    <div class="controls-panel">
      <div class="controls-title">Parameters</div>
      
      <div class="input-group">
        <div class="input-header">
          <label>Starting Balance</label>
          <span class="input-value" id="startingBalanceValue">$0</span>
        </div>
        <input type="range" id="startingBalance" min="0" max="2000000" step="5000" value="0">
        <div class="input-range">
          <span>$0</span>
          <span>$2,000,000</span>
        </div>
      </div>
      
      <div class="input-group">
        <div class="input-header">
          <label>Current Age</label>
          <span class="input-value" id="currentAgeValue">10 yrs</span>
        </div>
        <input type="range" id="currentAge" min="0" max="70" step="1" value="10">
        <div class="input-range">
          <span>Birth</span>
          <span>70 yrs</span>
        </div>
      </div>
      
      <div class="input-group">
        <div class="input-header">
          <label>Annual Return Rate</label>
          <span class="input-value" id="annualReturnValue">7%</span>
        </div>
        <input type="range" id="annualReturn" min="0" max="15" step="0.5" value="7">
        <div class="input-range">
          <span>0%</span>
          <span>15%</span>
        </div>
      </div>
      
      <!-- Basic mode contribution -->
      <div id="basicContribution">
        <div class="controls-title" style="margin-top: 8px;">Contribution</div>
        
        <div class="toggle-group">
          <button class="toggle-btn active" id="toggleWeekly">Weekly</button>
          <button class="toggle-btn" id="toggleMonthly">Monthly</button>
        </div>
        
        <div class="input-group" id="weeklyGroup">
          <div class="input-header">
            <label>Weekly Contribution</label>
            <span class="input-value" id="weeklyContributionValue">$100</span>
          </div>
          <input type="range" id="weeklyContribution" min="0" max="500" step="5" value="100">
          <div class="input-range">
            <span>$0</span>
            <span>$500</span>
          </div>
        </div>
        
        <div class="input-group" id="monthlyGroup" style="display: none;">
          <div class="input-header">
            <label>Monthly Contribution</label>
            <span class="input-value" id="monthlyContributionValue">$2,000</span>
          </div>
          <input type="range" id="monthlyContribution" min="0" max="1000" step="10" value="1000">
          <div class="input-range">
            <span>$0</span>
            <span>$1,000</span>
          </div>
        </div>
      </div>

      <!-- Advanced mode stages -->
      <div id="advancedContribution" style="display: none;">
        <div class="controls-title" style="margin-top: 8px;">Contribution Stages</div>
        <div id="stagesContainer"></div>
        <button class="add-stage-btn" id="addStageBtn">+ Add Stage</button>
      </div>
    </div>
    
    <div class="chart-panel">
      <div class="metrics-grid">
        <div class="metric-card highlight">
          <span class="metric-label">Final Balance</span>
          <span class="metric-value" id="metricFinal">$0</span>
          <span class="metric-subtext" id="metricYears">At age 100</span>
        </div>
        <div class="metric-card">
          <span class="metric-label">Total Contributed</span>
          <span class="metric-value" id="metricContributed">$0</span>
          <span class="metric-subtext">Including starting balance</span>
        </div>
        <div class="metric-card">
          <span class="metric-label">Total Growth</span>
          <span class="metric-value" id="metricGrowth">$0</span>
          <span class="metric-subtext" id="metricGrowthPct">0% of final balance</span>
        </div>
        <div class="metric-card">
          <span class="metric-label">Millionaire At</span>
          <span class="metric-value" id="metricMillionaire">—</span>
          <span class="metric-subtext" id="metricMillionaireSub">Age to reach $1M</span>
        </div>
      </div>
      
      <div class="chart-container">
        <canvas id="chart"></canvas>
      </div>
      
      <div class="chart-legend">
        <div class="legend-item">
          <div class="legend-dot" style="background: #10b981;"></div>
          <span>Portfolio Balance</span>
        </div>
        <div class="legend-item">
          <div class="legend-dot" style="background: #6366f1;"></div>
          <span>Total Contributed</span>
        </div>
        <div class="legend-item">
          <div class="legend-dot" style="background: rgba(16, 185, 129, 0.15); border: 1px solid rgba(16,185,129,0.4);"></div>
          <span>Growth (Interest Earned)</span>
        </div>
      </div>
    </div>
  </div>

  <script>
    const STORAGE_KEY = 'portfolio_growth_state_v2';
    
    const DEFAULTS = {
      startingBalance: 100000,
      currentAge: 10,
      annualReturn: 7,
      weeklyContribution: 100,
      monthlyContribution: 1000,
      useWeekly: true,
      mode: 'basic',
      stages: [
        { fromAge: 0, toAge: 18, amount: 100, frequency: 'weekly' },
        { fromAge: 19, toAge: 30, amount: 500, frequency: 'weekly' }
      ]
    };
    
    function loadState() {
      try {
        const saved = localStorage.getItem(STORAGE_KEY);
        if (saved) {
          const parsed = JSON.parse(saved);
          if (!parsed.stages) parsed.stages = JSON.parse(JSON.stringify(DEFAULTS.stages));
          if (!parsed.mode) parsed.mode = 'basic';
          return { ...DEFAULTS, ...parsed };
        }
      } catch (e) {}
      return JSON.parse(JSON.stringify(DEFAULTS));
    }
    
    function saveState() {
      try { localStorage.setItem(STORAGE_KEY, JSON.stringify(state)); } catch (e) {}
    }
    
    let state = loadState();
    let chart = null;
    
    const formatCurrency = (v) => {
      if (v >= 1000000) return `$${(v / 1000000).toFixed(2)}M`;
      if (v >= 1000) return `$${(v / 1000).toFixed(0)}K`;
      return `$${v.toFixed(0)}`;
    };
    
    const formatFullCurrency = (v) =>
      new Intl.NumberFormat('en-US', { style: 'currency', currency: 'USD', maximumFractionDigits: 0 }).format(v);

    // Get monthly contribution for a given age based on current mode
    function getMonthlyContribution(age) {
      if (state.mode === 'basic') {
        return state.useWeekly
          ? (state.weeklyContribution * 52) / 12
          : state.monthlyContribution;
      }
      // Advanced: find matching stage
      for (const stage of state.stages) {
        if (age >= stage.fromAge && age <= stage.toAge) {
          return stage.frequency === 'weekly'
            ? (stage.amount * 52) / 12
            : stage.amount;
        }
      }
      return 0; // No stage covers this age
    }
    
    function calculateProjection() {
      const data = [];
      let balance = state.startingBalance;
      let totalContributed = state.startingBalance;
      const monthlyReturn = state.annualReturn / 100 / 12;
      const maxAge = 100;
      
      for (let age = state.currentAge; age <= maxAge; age++) {
        data.push({ age, balance, totalContributed });
        
        const monthlyAmount = getMonthlyContribution(age);
        
        for (let month = 0; month < 12; month++) {
          balance += monthlyAmount;
          totalContributed += monthlyAmount;
          balance *= (1 + monthlyReturn);
        }
      }
      
      return data;
    }
    
    function updateChart() {
      const data = calculateProjection();
      const final = data[data.length - 1];
      const totalGrowth = final.balance - final.totalContributed;
      const growthPct = final.balance > 0 ? (totalGrowth / final.balance * 100).toFixed(1) : 0;
      
      const millionaireEntry = data.find(d => d.balance >= 1000000);
      
      document.getElementById('metricFinal').textContent = formatCurrency(final.balance);
      document.getElementById('metricYears').textContent = `At age 100 (${100 - state.currentAge} years)`;
      document.getElementById('metricContributed').textContent = formatCurrency(final.totalContributed);
      document.getElementById('metricGrowth').textContent = formatCurrency(totalGrowth);
      document.getElementById('metricGrowthPct').textContent = `${growthPct}% of final balance`;
      
      if (millionaireEntry) {
        document.getElementById('metricMillionaire').textContent = `Age ${millionaireEntry.age}`;
        document.getElementById('metricMillionaireSub').textContent =
          `In ${millionaireEntry.age - state.currentAge} years`;
      } else {
        document.getElementById('metricMillionaire').textContent = '—';
        document.getElementById('metricMillionaireSub').textContent = 'Not reached by 100';
      }
      
      const labels = data.map(d => d.age);
      const balances = data.map(d => d.balance);
      const contributions = data.map(d => d.totalContributed);
      
      const ctx = document.getElementById('chart').getContext('2d');
      
      if (chart) {
        chart.data.labels = labels;
        chart.data.datasets[0].data = balances;
        chart.data.datasets[1].data = contributions;
        chart.update('none');
      } else {
        chart = new Chart(ctx, {
          type: 'line',
          data: {
            labels,
            datasets: [
              {
                label: 'Portfolio Balance',
                data: balances,
                borderColor: '#10b981',
                backgroundColor: 'rgba(16, 185, 129, 0.15)',
                borderWidth: 2.5,
                fill: '+1',
                tension: 0.3,
                pointRadius: 0,
                pointHoverRadius: 6,
                pointHoverBackgroundColor: '#10b981',
                pointHoverBorderColor: '#fff',
                pointHoverBorderWidth: 2
              },
              {
                label: 'Total Contributed',
                data: contributions,
                borderColor: '#6366f1',
                backgroundColor: 'rgba(99, 102, 241, 0.08)',
                borderWidth: 2,
                fill: 'origin',
                tension: 0.3,
                pointRadius: 0,
                pointHoverRadius: 5,
                pointHoverBackgroundColor: '#6366f1',
                pointHoverBorderColor: '#fff',
                pointHoverBorderWidth: 2,
                borderDash: [5, 5]
              }
            ]
          },
          options: {
            responsive: true,
            maintainAspectRatio: false,
            interaction: { intersect: false, mode: 'index' },
            plugins: {
              legend: { display: false },
              tooltip: {
                backgroundColor: 'rgba(20, 20, 22, 0.95)',
                borderColor: '#333',
                borderWidth: 1,
                titleFont: { family: 'Space Mono', size: 11 },
                titleColor: '#666',
                bodyFont: { family: 'Space Mono', size: 14, weight: 'bold' },
                bodyColor: '#fff',
                padding: 14,
                cornerRadius: 10,
                displayColors: true,
                callbacks: {
                  title: (items) => `Age ${items[0].label}`,
                  label: (item) => `${item.dataset.label}: ${formatFullCurrency(item.raw)}`,
                  afterBody: (items) => {
                    const idx = items[0].dataIndex;
                    const bal = balances[idx];
                    const cont = contributions[idx];
                    const growth = bal - cont;
                    const pct = bal > 0 ? (growth / bal * 100).toFixed(1) : 0;
                    return `\nGrowth: ${formatFullCurrency(growth)} (${pct}%)`;
                  }
                }
              }
            },
            scales: {
              x: {
                grid: { color: '#222', drawBorder: false },
                ticks: { color: '#555', font: { family: 'Space Mono', size: 11 } },
                title: { display: true, text: 'Age', color: '#444', font: { family: 'Space Mono', size: 11 } }
              },
              y: {
                grid: { color: '#222', drawBorder: false },
                ticks: {
                  color: '#888',
                  font: { family: 'Space Mono', size: 11 },
                  callback: (v) => formatCurrency(v)
                },
                title: { display: true, text: 'Amount', color: '#888', font: { family: 'Space Mono', size: 10 } },
                beginAtZero: true
              }
            }
          }
        });
      }
    }
    
    function syncUI() {
      document.getElementById('startingBalance').value = state.startingBalance;
      document.getElementById('startingBalanceValue').textContent = formatFullCurrency(state.startingBalance);
      document.getElementById('currentAge').value = state.currentAge;
      document.getElementById('currentAgeValue').textContent = state.currentAge === 0 ? 'Birth' : `${state.currentAge} yrs`;
      document.getElementById('annualReturn').value = state.annualReturn;
      document.getElementById('annualReturnValue').textContent = `${state.annualReturn}%`;
      document.getElementById('weeklyContribution').value = state.weeklyContribution;
      document.getElementById('weeklyContributionValue').textContent = formatFullCurrency(state.weeklyContribution);
      document.getElementById('monthlyContribution').value = state.monthlyContribution;
      document.getElementById('monthlyContributionValue').textContent = formatFullCurrency(state.monthlyContribution);
      
      if (state.useWeekly) {
        document.getElementById('toggleWeekly').classList.add('active');
        document.getElementById('toggleMonthly').classList.remove('active');
        document.getElementById('weeklyGroup').style.display = 'block';
        document.getElementById('monthlyGroup').style.display = 'none';
      } else {
        document.getElementById('toggleMonthly').classList.add('active');
        document.getElementById('toggleWeekly').classList.remove('active');
        document.getElementById('monthlyGroup').style.display = 'block';
        document.getElementById('weeklyGroup').style.display = 'none';
      }

      // Tab state
      if (state.mode === 'advanced') {
        document.getElementById('tabAdvanced').classList.add('active');
        document.getElementById('tabBasic').classList.remove('active');
        document.getElementById('basicContribution').style.display = 'none';
        document.getElementById('advancedContribution').style.display = 'block';
      } else {
        document.getElementById('tabBasic').classList.add('active');
        document.getElementById('tabAdvanced').classList.remove('active');
        document.getElementById('basicContribution').style.display = 'block';
        document.getElementById('advancedContribution').style.display = 'none';
      }

      renderStages();
    }

    // ========================
    // Advanced Stages
    // ========================

    function renderStages() {
      const container = document.getElementById('stagesContainer');
      container.innerHTML = '';

      state.stages.forEach((stage, i) => {
        const card = document.createElement('div');
        card.className = 'stage-card';
        
        const freqLabel = stage.frequency === 'weekly' ? 'Weekly' : 'Monthly';
        const amountMax = stage.frequency === 'weekly' ? 500 : 1000;
        const amountStep = stage.frequency === 'weekly' ? 5 : 10;

        card.innerHTML = `
          <div class="stage-header">
            <span class="stage-label">Stage ${i + 1}</span>
            ${state.stages.length > 1 ? `<button class="stage-remove" data-idx="${i}">×</button>` : ''}
          </div>
          <div class="stage-freq-toggle">
            <button class="stage-freq-btn ${stage.frequency === 'weekly' ? 'active' : ''}" data-idx="${i}" data-freq="weekly">Weekly</button>
            <button class="stage-freq-btn ${stage.frequency === 'monthly' ? 'active' : ''}" data-idx="${i}" data-freq="monthly">Monthly</button>
          </div>
          <div class="input-group">
            <div class="input-header">
              <label>From Age</label>
              <span class="input-value">${stage.fromAge}</span>
            </div>
            <input type="range" data-idx="${i}" data-field="fromAge" min="0" max="99" step="1" value="${stage.fromAge}">
          </div>
          <div class="input-group">
            <div class="input-header">
              <label>To Age</label>
              <span class="input-value">${stage.toAge}</span>
            </div>
            <input type="range" data-idx="${i}" data-field="toAge" min="0" max="100" step="1" value="${stage.toAge}">
          </div>
          <div class="input-group">
            <div class="input-header">
              <label>${freqLabel} Contribution</label>
              <span class="input-value">${formatFullCurrency(stage.amount)}</span>
            </div>
            <input type="range" data-idx="${i}" data-field="amount" min="0" max="${amountMax}" step="${amountStep}" value="${stage.amount}">
          </div>
        `;

        container.appendChild(card);
      });

      // Attach stage event listeners
      container.querySelectorAll('.stage-remove').forEach(btn => {
        btn.addEventListener('click', () => {
          const idx = parseInt(btn.dataset.idx);
          state.stages.splice(idx, 1);
          saveState(); renderStages(); updateChart();
        });
      });

      container.querySelectorAll('.stage-freq-btn').forEach(btn => {
        btn.addEventListener('click', () => {
          const idx = parseInt(btn.dataset.idx);
          state.stages[idx].frequency = btn.dataset.freq;
          // Reset amount to sensible default when switching
          if (btn.dataset.freq === 'weekly' && state.stages[idx].amount > 5000) {
            state.stages[idx].amount = 500;
          }
          saveState(); renderStages(); updateChart();
        });
      });

      container.querySelectorAll('input[type="range"]').forEach(input => {
        input.addEventListener('input', (e) => {
          const idx = parseInt(e.target.dataset.idx);
          const field = e.target.dataset.field;
          const val = parseFloat(e.target.value);
          state.stages[idx][field] = val;
          
          // Update the displayed value
          const valueSpan = e.target.closest('.input-group').querySelector('.input-value');
          if (field === 'amount') {
            valueSpan.textContent = formatFullCurrency(val);
          } else {
            valueSpan.textContent = val;
          }
          
          saveState(); updateChart();
        });
      });
    }
    
    function setupListeners() {
      document.getElementById('startingBalance').addEventListener('input', (e) => {
        state.startingBalance = parseFloat(e.target.value);
        document.getElementById('startingBalanceValue').textContent = formatFullCurrency(state.startingBalance);
        saveState(); updateChart();
      });
      
      document.getElementById('currentAge').addEventListener('input', (e) => {
        state.currentAge = parseInt(e.target.value);
        document.getElementById('currentAgeValue').textContent = state.currentAge === 0 ? 'Birth' : `${state.currentAge} yrs`;
        saveState(); updateChart();
      });
      
      document.getElementById('annualReturn').addEventListener('input', (e) => {
        state.annualReturn = parseFloat(e.target.value);
        document.getElementById('annualReturnValue').textContent = `${state.annualReturn}%`;
        saveState(); updateChart();
      });
      
      document.getElementById('weeklyContribution').addEventListener('input', (e) => {
        state.weeklyContribution = parseFloat(e.target.value);
        document.getElementById('weeklyContributionValue').textContent = formatFullCurrency(state.weeklyContribution);
        saveState(); updateChart();
      });
      
      document.getElementById('monthlyContribution').addEventListener('input', (e) => {
        state.monthlyContribution = parseFloat(e.target.value);
        document.getElementById('monthlyContributionValue').textContent = formatFullCurrency(state.monthlyContribution);
        saveState(); updateChart();
      });
      
      document.getElementById('toggleWeekly').addEventListener('click', () => {
        state.useWeekly = true;
        document.getElementById('toggleWeekly').classList.add('active');
        document.getElementById('toggleMonthly').classList.remove('active');
        document.getElementById('weeklyGroup').style.display = 'block';
        document.getElementById('monthlyGroup').style.display = 'none';
        saveState(); updateChart();
      });
      
      document.getElementById('toggleMonthly').addEventListener('click', () => {
        state.useWeekly = false;
        document.getElementById('toggleMonthly').classList.add('active');
        document.getElementById('toggleWeekly').classList.remove('active');
        document.getElementById('monthlyGroup').style.display = 'block';
        document.getElementById('weeklyGroup').style.display = 'none';
        saveState(); updateChart();
      });

      // Tab switching
      document.getElementById('tabBasic').addEventListener('click', () => {
        state.mode = 'basic';
        document.getElementById('tabBasic').classList.add('active');
        document.getElementById('tabAdvanced').classList.remove('active');
        document.getElementById('basicContribution').style.display = 'block';
        document.getElementById('advancedContribution').style.display = 'none';
        saveState(); updateChart();
      });

      document.getElementById('tabAdvanced').addEventListener('click', () => {
        state.mode = 'advanced';
        document.getElementById('tabAdvanced').classList.add('active');
        document.getElementById('tabBasic').classList.remove('active');
        document.getElementById('basicContribution').style.display = 'none';
        document.getElementById('advancedContribution').style.display = 'block';
        saveState(); renderStages(); updateChart();
      });

      // Add stage
      document.getElementById('addStageBtn').addEventListener('click', () => {
        const lastStage = state.stages[state.stages.length - 1];
        const newFrom = lastStage ? lastStage.toAge + 1 : 0;
        state.stages.push({
          fromAge: Math.min(newFrom, 99),
          toAge: Math.min(newFrom + 10, 100),
          amount: 500,
          frequency: 'weekly'
        });
        saveState(); renderStages(); updateChart();
      });
      
      document.getElementById('btnDefault').addEventListener('click', () => {
        state = JSON.parse(JSON.stringify(DEFAULTS));
        saveState(); syncUI(); updateChart();
      });
    }
    
    document.addEventListener('DOMContentLoaded', () => {
      setupListeners();
      syncUI();
      updateChart();
    });
  </script>
</body>
</html>
